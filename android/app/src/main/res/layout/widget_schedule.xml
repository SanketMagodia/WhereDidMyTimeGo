<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_schedule_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:baselineAligned="false"
    android:padding="0dp"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_marginEnd="6dp"
        android:background="@drawable/widget_sticky_bg">

        <ListView
            android:id="@+id/schedule_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/transparent"
            android:dividerHeight="6dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="50dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:background="@drawable/widget_bg"
        android:gravity="center_vertical">
        
        <LinearLayout
            android:id="@+id/tile_0_box"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="4dp"
            android:background="@drawable/widget_item_selected_bg">
            <TextView
                android:id="@+id/tile_0_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tile_0_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#EEEEEE"
                android:textSize="9sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tile_1_box"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="4dp"
            android:background="@android:color/transparent">
            <TextView
                android:id="@+id/tile_1_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#A0A0A0"
                android:textSize="10sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tile_1_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#808080"
                android:textSize="9sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tile_2_box"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="4dp"
            android:background="@android:color/transparent">
            <TextView
                android:id="@+id/tile_2_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#A0A0A0"
                android:textSize="10sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tile_2_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#808080"
                android:textSize="9sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tile_3_box"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@android:color/transparent">
            <TextView
                android:id="@+id/tile_3_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#A0A0A0"
                android:textSize="10sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tile_3_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#808080"
                android:textSize="9sp"/>
        </LinearLayout>
        
    </LinearLayout>
</LinearLayout>
